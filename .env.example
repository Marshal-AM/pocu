# Hedera testnet (Hardhat + Hedera SDK)
ACCOUNT_ID=0.0.xxxxx
HEX_ENCODED_PRIVATE_KEY=0x...
DER_ENCODED_PRIVATE_KEY=303...
PRIVATE_KEY=303...
EVM_ADDRESS=0x...
HEDERA_RPC_URL=https://testnet.hashio.io/api

# Groq (agent LLM)
GROQ_API_KEY=gsk_...

# Kaggle (token only — from kaggle.com/settings → API)
KAGGLE_API_TOKEN=KGAT_...

# Pinata IPFS (optional, training manifest pin)
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs
CPU_IPFS_MODE=1
CPU_IPFS_PIN_SCOPE=final

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Services
AGENT_SERVICE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_AGENT_URL=http://127.0.0.1:8000
# Set to 1 only if you are NOT running npm run jobs:worker separately
AGENT_EMBEDDED_WORKER=0

# Wallet / AP2 (see web/.env.example for NEXT_PUBLIC_*)
ALLOWANCE_HBAR=200
BATCH_GAS_BUFFER_HBAR=15
JOB_COST_BUFFER_HBAR=10
AP2_SESSION_BUDGET_HBAR=200
AP2_CHAT_TURN_HBAR=0.1
AP2_MANDATE_TTL_SEC=7200
MODEL_NFT_TOKEN_ID=0.0.xxxxx
HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com
